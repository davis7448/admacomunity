rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isLider() {
      return isSignedIn() && exists(/databases/$(database)/documents/lideres/$(request.auth.uid));
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isNonEmptyString(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }

    function isOptionalString(v, maxLen) {
      return v == null || (v is string && v.size() <= maxLen);
    }

    function isValidUserDoc() {
      return isNonEmptyString(request.resource.data.email, 160)
        && isOptionalString(request.resource.data.nombre, 120)
        && isOptionalString(request.resource.data.foto, 5000)
        && isOptionalString(request.resource.data.comunidadId, 128)
        && isOptionalString(request.resource.data.telefono, 40)
        && (request.resource.data.rol == null
          || request.resource.data.rol in ['usuario', 'lider', 'admin']);
    }

    function isValidComunidadDoc() {
      return isNonEmptyString(request.resource.data.nombre, 120)
        && isNonEmptyString(request.resource.data.codigo, 64)
        && isOptionalString(request.resource.data.logo, 10000)
        && isOptionalString(request.resource.data.liderId, 128);
    }

    function isValidRetoDoc() {
      return isNonEmptyString(request.resource.data.titulo, 140)
        && (request.resource.data.meta is int || request.resource.data.meta is float || request.resource.data.meta is string)
        && isOptionalString(request.resource.data.descripcion, 2000)
        && isOptionalString(request.resource.data.imagen, 10000)
        && isOptionalString(request.resource.data.comunidadId, 128)
        && (request.resource.data.tipo == null
          || request.resource.data.tipo in ['facturacion', 'facturación', 'unidades', 'guias', 'guías']);
    }

    function isValidInscripcionDoc() {
      return isNonEmptyString(request.resource.data.userId, 128)
        && isNonEmptyString(request.resource.data.retoId, 128)
        && isOptionalString(request.resource.data.comunidadId, 128);
    }

    function comunidadEsDeLider(comunidadId) {
      return isLider()
        && comunidadId != null
        && exists(/databases/$(database)/documents/comunidades/$(comunidadId))
        && get(/databases/$(database)/documents/comunidades/$(comunidadId)).data.liderId == request.auth.uid;
    }

    // Helper: check if target user doc belongs to a comunidad owned by current líder
    // Uses resource.data so it works for both single-doc reads and filtered queries.
    function recursoUsuarioEsDeMiComunidad() {
      return isLider()
        && resource.data.comunidadId != null
        && comunidadEsDeLider(resource.data.comunidadId);
    }

    // Users - SEGURIDAD MEJORADA
    match /users/{userId} {
      // Lectura: propio, admin, líder de su comunidad
      allow read: if isAdmin()
        || isSelf(userId)
        || recursoUsuarioEsDeMiComunidad();

      allow create: if (isAdmin() || isSelf(userId)) && isValidUserDoc();
      allow update: if (isAdmin() || isSelf(userId)) && isValidUserDoc();
      allow delete: if isAdmin();
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isAdmin() || isSelf(adminId);
      allow write: if isAdmin();
    }

    // Lideres
    match /lideres/{liderId} {
      allow read: if isAdmin() || isSelf(liderId);
      allow create: if isAdmin();
      allow update: if isAdmin() || isSelf(liderId);
      allow delete: if isAdmin();
    }

    // Comunidades
    match /comunidades/{comunidadId} {
      allow read: if true;  // Público para registro

      allow create: if isValidComunidadDoc() && (
          isAdmin()
          || (isLider() && request.resource.data.liderId == request.auth.uid)
        );

      allow update: if isValidComunidadDoc() && (
          isAdmin()
          || (isLider() && resource.data.liderId == request.auth.uid)
        );

      allow delete: if isAdmin();
    }

    // Retos
    match /retos/{retoId} {
      allow read: if isSignedIn();

      allow create: if isValidRetoDoc() && (
          isAdmin()
          || (isLider() && comunidadEsDeLider(request.resource.data.comunidadId))
        );

      allow update: if isValidRetoDoc() && (
          isAdmin()
          || (isLider() && comunidadEsDeLider(resource.data.comunidadId))
        );

      allow delete: if isAdmin()
        || (isLider() && comunidadEsDeLider(resource.data.comunidadId));
    }

    // Inscripciones
    match /inscripciones/{inscripcionId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (isLider() && comunidadEsDeLider(resource.data.comunidadId));

      allow create: if isValidInscripcionDoc() && (
          isAdmin()
          || (isSignedIn() && request.resource.data.userId == request.auth.uid)
        );

      allow update, delete: if isAdmin();
    }

    // Ventas - SEGURIDAD MEJORADA
    match /ventas/{ventaId} {
      // Solo admin y líderes pueden leer ventas
      allow read: if isAdmin() || isLider();

      // Solo admin puede modificar; validaciones de estructura se realizan en importador
      allow create, update, delete: if isAdmin();
    }

    // Import mappings
    match /import_mappings/{mappingId} {
      allow read, write: if isAdmin()
        || (isSignedIn() && mappingId.matches('^' + request.auth.uid + '__.*$'));
    }

    // Order allocations - SEGURIDAD MEJORADA
    match /order_allocations/{orderKey} {
      allow read: if isSignedIn();
      // Solo admin puede escribir allocations (para importar datos)
      allow write: if isAdmin();
    }

    // Cached rankings
    match /reto_rankings/{retoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isLider();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
